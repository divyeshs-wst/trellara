{%- comment -%} Trellara — 404 Section {%- endcomment -%}

<section class="trl-404">
  <div class="trl-container trl-404__inner">
    <h1>{{ section.settings.heading | default: '404 — Page Not Found' }}</h1>
    <p>{{ section.settings.text | default: "The page you're looking for doesn't exist." }}</p>
    <a href="{{ routes.root_url }}" class="trl-button">Back to Home</a>
  </div>
</section>

{% schema %}
{
  "name": "404 Content",
  "tag": null,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "404 — Page Not Found" },
    { "type": "textarea", "id": "text", "label": "Message", "default": "The page you're looking for doesn't exist." }
  ],
  "presets": [
    { "name": "404 Content" }
  ]
}
{% endschema %}
