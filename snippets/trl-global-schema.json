// ============================================================
// TRELLARA — Global Wrapper Schema Settings
// ------------------------------------------------------------
// This is NOT a live Liquid file (Shopify schema can't import
// JSON). Copy-paste this array into the "settings" array of
// EVERY widget's {% schema %} block — right after the widget's
// own unique/content settings, under a "Global Settings" header.
//
// Pairs with: snippets/trl-global-settings.liquid
// ============================================================

[
  {
    "type": "header",
    "content": "Global Settings"
  },
  {
    "type": "text",
    "id": "trl_css_class",
    "label": "CSS Class",
    "info": "Add one or more custom class names, space separated"
  },
  {
    "type": "text",
    "id": "trl_css_id",
    "label": "CSS ID",
    "info": "Optional custom ID for anchor links or JS targeting"
  },
  {
    "type": "select",
    "id": "trl_display",
    "label": "Display",
    "options": [
      { "value": "block", "label": "Block" },
      { "value": "inline-block", "label": "Inline Block" },
      { "value": "flex", "label": "Flex" },
      { "value": "none", "label": "Hidden" }
    ],
    "default": "block"
  },
  {
    "type": "text",
    "id": "trl_width",
    "label": "Width",
    "info": "e.g. 100%, 300px, auto"
  },
  {
    "type": "text",
    "id": "trl_max_width",
    "label": "Max Width",
    "info": "e.g. 1200px, 100%"
  },
  {
    "type": "text",
    "id": "trl_height",
    "label": "Height",
    "info": "e.g. auto, 400px"
  },
  {
    "type": "header",
    "content": "Spacing"
  },
  {
    "type": "range",
    "id": "trl_margin_top",
    "label": "Margin Top",
    "min": 0,
    "max": 200,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "range",
    "id": "trl_margin_bottom",
    "label": "Margin Bottom",
    "min": 0,
    "max": 200,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "range",
    "id": "trl_margin_left",
    "label": "Margin Left",
    "min": 0,
    "max": 200,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "range",
    "id": "trl_margin_right",
    "label": "Margin Right",
    "min": 0,
    "max": 200,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "range",
    "id": "trl_padding_top",
    "label": "Padding Top",
    "min": 0,
    "max": 200,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "range",
    "id": "trl_padding_bottom",
    "label": "Padding Bottom",
    "min": 0,
    "max": 200,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "range",
    "id": "trl_padding_left",
    "label": "Padding Left",
    "min": 0,
    "max": 200,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "range",
    "id": "trl_padding_right",
    "label": "Padding Right",
    "min": 0,
    "max": 200,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "header",
    "content": "Background & Border"
  },
  {
    "type": "color",
    "id": "trl_bg_color",
    "label": "Wrapper Background Color"
  },
  {
    "type": "image_picker",
    "id": "trl_bg_image",
    "label": "Wrapper Background Image"
  },
  {
    "type": "range",
    "id": "trl_border_width",
    "label": "Border Width",
    "min": 0,
    "max": 20,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "color",
    "id": "trl_border_color",
    "label": "Border Color"
  },
  {
    "type": "range",
    "id": "trl_border_radius",
    "label": "Border Radius",
    "min": 0,
    "max": 100,
    "step": 1,
    "unit": "px",
    "default": 0
  },
  {
    "type": "header",
    "content": "Custom CSS"
  },
  {
    "type": "textarea",
    "id": "trl_custom_css",
    "label": "Custom CSS",
    "info": "Raw CSS scoped to this widget instance only"
  }
]
